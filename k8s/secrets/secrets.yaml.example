# Copy to secrets.yaml and fill in values, then:
#   kubectl apply -f k8s/secrets/secrets.yaml
#
# Values must be base64-encoded:
#   echo -n "myvalue" | base64
#
# IMPORTANT: Never commit secrets.yaml to git!
apiVersion: v1
kind: Secret
metadata:
  name: riveroverflow-secrets
  namespace: riveroverflow
type: Opaque
data:
  POSTGRES_USER: dHJhZGVy          # trader
  POSTGRES_PASSWORD: cGFzc3dvcmQ=  # password (CHANGE THIS!)
  JWT_SECRET: Y2hhbmdlLW1lLXRvLWEtcmFuZG9tLXNlY3JldA==  # (CHANGE THIS!)
  KIS_APP_KEY: ""
  KIS_APP_SECRET: ""
  KIS_ACCOUNT_NO: ""

# ── 한국투자증권 (Korea Investment & Securities) ──────────────────────────────
# 발급처: https://apiportal.koreainvestment.com
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=12345678-01         # 계좌번호 (예: 12345678-01)
KIS_IS_VIRTUAL=true                # true=모의투자, false=실전투자

# ── Kiwoom (선택 - Windows bridge 필요) ───────────────────────────────────────
KIWOOM_BRIDGE_URL=http://kiwoom-bridge:9091
KIWOOM_USER_ID=
KIWOOM_PASSWORD=
KIWOOM_CERT_PASSWORD=

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=trader
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=riveroverflow
DATABASE_URL=postgresql+asyncpg://trader:change_me_in_production@postgres:5432/riveroverflow

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_256_bit_secret
JWT_EXPIRE_MINUTES=1440            # 24시간

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | production
LOG_LEVEL=INFO
PORT=8080

# ── Admin user (초기 설정) ────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
